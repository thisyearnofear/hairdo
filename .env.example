# Get your Replicate API token at https://www.replicate.com/account
REPLICATE_API_TOKEN=

# Get your WalletConnect project ID at https://cloud.walletconnect.com
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# Optional: Google Analytics tracking ID
NEXT_PUBLIC_GTAG_ID=

# Deployer wallet for HairdoProtocol contract deployment (Lisk Sepolia testnet)
# Generate locally with: node -e "const v=require('viem/accounts');const pk=v.generatePrivateKey();const a=v.privateKeyToAccount(pk);console.log('PRIVATE_KEY='+pk);console.log('ADDRESS='+a.address)"
# NEVER commit your real key — keep it in .env.local (gitignored)
DEPLOYER_PRIVATE_KEY=
DEPLOYER_ADDRESS=
